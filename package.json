  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:wasm && tsc && vite build",
    "serve": "vite preview",
    "type-check": "tsc --noemit",
    "build:asc": "cd src/engine/wasmEngine/wasm && make build_asc",
    "build:wat": "cd src/engine/wasmEngine/wasm && make build_wat",
    "build:wasm": "pnpm run build:asc && pnp run build:wat",
    "onchange:wasm": "onchange -v -i 'src/engine/wasmEngine/wasm/compile_asc.mjs' 'src/engine/wasmEngine/wasm/wasmConfig.mjs' 'src/engine/wasmEngine/wasm/makefile' 'src/engine/wasmEngine/wasm/asconfig.json' 'src/engine/wasmEngine/wasm/src/**/*.ts' -- make --no-print-directory -C src/engine/wasmEngine/wasm ",
    "format": "prettier --write src",
    "lint": "pnpm run lint:tsc && pnpm run lint:eslint && pnpm run lint:ts-coverage",
    "lint:tsc": "tsc",
    "lint:eslint": "eslint src --fix --cache",
    "lint:ts-coverage": "type-coverage",
    "ts-coverage:report": "typescript-coverage-report"
  },
  "dependencies": {
    "@jsier/retrier": "^1.2.4",
