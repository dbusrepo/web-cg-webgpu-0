    "preact": "^10.25.3",
    "react": "^18.2.0",
    "screenfull": "^6.0.2",
    "simple-color-picker": "^1.0.5",
    "tinycolor2": "^1.6.0",
    "tweakpane": "^4.0.5",
    "uuid": "^9.0.1",
    "wolfy87-eventemitter": "^5.2.9"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
